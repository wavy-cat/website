---
import Layout from "../layouts/Layout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ProjectLinks from "../components/ProjectLinks.astro";
import { Picture } from "astro:assets";
import socials from "../socials";
import projects from "../projects";
import avatar from "../assets/avatar.png";
---

<Layout title="WavyCat" description="Just a website with various links">
    <h1 class="text-2xl">WavyCat</h1>
    <p>
        Software engineer with experience in Go, TypeScript & Kotlin.
    </p>
    <SocialLinks buttons={socials} />

    <hr class="w-full h-0.5 my-5 mx-auto bg-neutral-300 border-0">

    <ProjectLinks buttons={projects} />
</Layout>
